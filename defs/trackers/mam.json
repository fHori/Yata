{
  "schema_version": 1,
  "key": "mam",
  "name": "MyAnonamouse",
  "abbr": "MAM",
  "url": "https://www.myanonamouse.net",
  "type": "custom",
  "last_updated": "2026-07-03",
  "approved_by": {
    "name": "Support Staff",
    "role": "Staff",
    "date": "2026-05-15",
    "note": "Staff said as long as you are only using the API as a user to get your own stats, it is fine. They do not want people scraping the site other users' stats."
  },
  "api_field_map": {
    "seedbonus": "bonus_points"
  },
  "scrape": {
    "disable_scraping": true
  },
  "api": {
    "path": "/jsonLoad.php?snatch_summary",
    "auth_method": "api_key_query",
    "api_key_param": "mam_id",
    "field_map": {
      "classname": "group",
      "inactHnr.count": "hit_and_runs",
      "inactSat.count": "inactive_satisfied",
      "leeching.count": "leeching",
      "ratio": "ratio",
      "reseed.count": "reseed_count",
      "sSat.count": "seeding_satisfied",
      "seedHnr.count": "seeding_hnr",
      "seedUnsat.count": "seeding_unsatisfied",
      "seedbonus": "seedbonus",
      "username": "username",
      "wedges": "fl_tokens"
    },
    "sum_fields": {
      "seeding": [
        "sSat.count",
        "seedHnr.count",
        "seedUnsat.count"
      ]
    },
    "sum_bytes_fields": {
      "seed_size": [
        "sSat.size",
        "seedHnr.size",
        "seedUnsat.size"
      ]
    },
    "byte_fields": {
      "downloaded_bytes": "downloaded",
      "uploaded_bytes": "uploaded"
    },
    "buffer_from_bytes": true,
    "api_key_hint": "Preferences > Security > Create Session"
  },
  "invite_requirements": {
    "min_class": "Power User",
    "min_uploaded": "1 TB",
    "min_ratio": 2.0,
    "min_age": "6M",
    "note": "MAM gates invite-forum access separately from user class: Power User plus all of the above. Some invite threads additionally require VIP (purchasable with bonus points). Always check MAM's official guidance."
  },
